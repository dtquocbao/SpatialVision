# ── Downloaded / generated data (recreated by notebooks) ──────────────────────
data/raw/**
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
!data/processed/*.csv
data/processed/*.h5ad
data/processed/*.zarr

# ── Archives ───────────────────────────────────────────────────────────────────
*.zip
*.tar.gz
*.tgz

# ── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# ── OS / editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/

